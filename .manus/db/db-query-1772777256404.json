  "query": "\nSELECT \n  bci.id as bci_id,\n  bci.conferenceId,\n  bci.productId,\n  bci.batch as bci_batch,\n  bci.tenantId as bci_tenant,\n  roi.id as roi_id,\n  roi.receivingOrderId,\n  roi.productId as roi_productId,\n  roi.batch as roi_batch,\n  roi.tenantId as roi_tenant,\n  roi.expectedQuantity\nFROM blindConferenceItems bci\nLEFT JOIN blindConferenceSessions bcs ON bcs.id = bci.conferenceId\nLEFT JOIN receivingOrderItems roi ON (\n  roi.receivingOrderId = bcs.receivingOrderId\n  AND roi.productId = bci.productId\n  AND roi.tenantId = bci.tenantId\n)\nORDER BY bci.id DESC\nLIMIT 15;\n",
