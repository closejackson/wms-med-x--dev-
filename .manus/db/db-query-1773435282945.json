{
  "query": "\nSELECT \n  wl.id,\n  wl.code,\n  wl.status,\n  COALESCE(SUM(i.quantity), 0) as total_stock,\n  COUNT(i.id) as inventory_rows\nFROM warehouseLocations wl\nLEFT JOIN inventory i ON i.locationId = wl.id AND i.quantity > 0\nWHERE wl.status = 'occupied'\nGROUP BY wl.id, wl.code, wl.status\nHAVING total_stock = 0\nORDER BY wl.code\nLIMIT 30;\n",
